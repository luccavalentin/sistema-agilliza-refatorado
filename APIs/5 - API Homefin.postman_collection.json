              "mode": "raw",
              "raw": "{\n  \"operacao\": {\n    \"idOperacao\": \"1\"\n  },\n  \"regional\": {\n    \"idRegional\": \"{{idRegional}}\"\n  },\n  \"parceiro\": {\n    \"idParceiro\": \"{{idParceiro}}\"\n  },\n  \"usuarioParceiro\": {\n    \"idUsuarioParceiro\": \"{{idUsuarioParceiro}}\"\n  },\n  \"tipoImovel\": {\n    \"id\": \"AP\"\n  },\n  \"usoImovel\": {\n    \"id\": \"R\"\n  },\n  \"uf\": {\n    \"codigo\": \"SP\"\n  },\n  \"valorImovel\": {{valorImovel}},\n  \"valorFinanciamento\": {{valorFinanciamento}},\n  \"prazo\": {{prazo}},\n  \"utilizaFgtsSimulacao\": \"N\",\n  \"bancos\": [\n    {\n      \"idBanco\": 45,\n      \"codigoBanco\": 237,\n      \"nomeBanco\": \"Banco Bradesco\",\n      \"flagSimulacao\": \"{{flagSimulacao_Bradesco}}\"\n    },\n    {\n      \"idBanco\": 61,\n      \"codigoBanco\": 341,\n      \"nomeBanco\": \"Banco Itaú\",\n      \"flagSimulacao\": \"{{flagSimulacao_Itau}}\"\n    },\n    {\n      \"idBanco\": 9,\n      \"codigoBanco\": 33,\n      \"nomeBanco\": \"Banco Santander\",\n      \"flagSimulacao\": \"{{flagSimulacao_Santander}}\"\n    }\n  ],\n  \"cpfCnpj\": \"{{cpfCnpj_Cliente}}\",\n  \"nome\": \"{{nome_Cliente}}\",\n  \"rendaTotal\": {{renda_Cliente}},\n  \"codigoSistemaAmortizacaoBanco\": {\n    \"id\": \"S\"\n  },\n  \"dataNascimento\": \"2001-02-12\",\n  \"email\": \"joaofarias@homefin.com.br\",\n  \"celular\": \"41999107330\",\n  \"fgCompoeRenda\": false,\n  \"situacaoImovel\": {\n    \"codigo\": \"U\"\n  },\n  \"fgFinanciarDespesas\": \"N\",\n  \"tipoEstadoCivil\": {\n    \"id\": \"S\"\n  }\n}",
