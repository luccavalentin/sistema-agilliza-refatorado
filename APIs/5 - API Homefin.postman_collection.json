  "item": [
    {
      "name": "1. Autenticação",
      "item": [
        {
          "name": "Gerar Token (JWT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.jwt) {",
                  "    pm.environment.set(\"jwt\", jsonData.jwt);",
                  "    pm.environment.set(\"idParceiro\", jsonData.usuario.idParceiro);",
                  "    pm.environment.set(\"idRegional\", jsonData.usuario.idRegional);",
                  "    pm.environment.set(\"idUsuarioParceiro\", jsonData.usuario.idUsuarioParceiro);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "packages": {},
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"secretId\": \"{{SECRET_ID}}\",\n  \"secretKey\": \"{{SECRET_KEY}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "token"
              ]
            }
          },
          "response": []
        }
      ]
    },
